{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "content": "## LoRA Adapter Observability\n\nPer-adapter metrics for request rate, latency, token throughput, and GPU memory. Each adapter (identified by `model_name`) is tracked independently.", "mode": "markdown" },
      "title": "LoRA Adapter Observability",
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Requests per second broken down by adapter name. Shows which adapters are receiving traffic.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 2 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "sortBy": "Max", "sortDesc": true } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(model_name) (rate(vllm:request_success_total[5m]))", "legendFormat": "{{ model_name }}", "refId": "A" }],
      "title": "Request Rate by Adapter",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "p50, p95, and p99 end-to-end request latency per adapter.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 2 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum(rate(vllm:e2e_request_latency_seconds_bucket[5m])) by (le, model_name))", "legendFormat": "p50 {{ model_name }}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(vllm:e2e_request_latency_seconds_bucket[5m])) by (le, model_name))", "legendFormat": "p95 {{ model_name }}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum(rate(vllm:e2e_request_latency_seconds_bucket[5m])) by (le, model_name))", "legendFormat": "p99 {{ model_name }}", "refId": "C" }
      ],
      "title": "Request Latency by Adapter (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Prompt (input) tokens per second by adapter.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "sortBy": "Max", "sortDesc": true } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(model_name) (rate(vllm:prompt_tokens_total[5m]))", "legendFormat": "{{ model_name }}", "refId": "A" }],
      "title": "Input Token Throughput by Adapter",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Generation (output) tokens per second by adapter.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "sortBy": "Max", "sortDesc": true } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(model_name) (rate(vllm:generation_tokens_total[5m]))", "legendFormat": "{{ model_name }}", "refId": "A" }],
      "title": "Output Token Throughput by Adapter",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Time to first token (TTFT) by adapter. Critical for interactive use cases.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le, model_name))", "legendFormat": "p50 {{ model_name }}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le, model_name))", "legendFormat": "p95 {{ model_name }}", "refId": "B" }
      ],
      "title": "Time to First Token by Adapter (p50/p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "GPU KV cache utilization and number of running/waiting requests. High cache usage with many LoRA adapters indicates memory pressure.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "max": 1, "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] }, "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "vllm:gpu_cache_usage_perc", "legendFormat": "GPU cache {{ pod }}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "vllm:cpu_cache_usage_perc", "legendFormat": "CPU cache {{ pod }}", "refId": "B" }
      ],
      "title": "GPU/CPU KV Cache Utilization",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of currently running and waiting requests by adapter. A growing waiting queue indicates the adapter is saturated.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 8,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(model_name) (vllm:num_requests_running)", "legendFormat": "running {{ model_name }}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(model_name) (vllm:num_requests_waiting)", "legendFormat": "waiting {{ model_name }}", "refId": "B" }
      ],
      "title": "Running / Waiting Requests by Adapter",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "tags": ["lora", "llminferenceservice", "vllm"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "LoRA Adapter Observability",
  "uid": "lora-adapter-observability"
}
